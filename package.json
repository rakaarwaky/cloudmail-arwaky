{
  "name": "cloudmail-arwaky",
  "version": "1.0.4",
  "type": "module",
  "workspaces": [
    "src/surfaces/web"
  ],
  "scripts": {
    "build": "npm run build -w src/surfaces/web",
    "check": "npm run check -w src/surfaces/web",
    "cf:dev": "npm run build && npx wrangler dev",
    "deploy": "npm run build && npx wrangler deploy --config ./wrangler.toml",
    "lint:aes": "python3 linter/aes_linter.py",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke/",
    "test:sanity": "vitest run tests/sanity/",
    "test:unit": "vitest run tests/unit/",
    "test:functional": "vitest run tests/functional/",
    "test:integration": "vitest run tests/integration/",
    "test:regression": "vitest run tests/regression/",
    "test:acceptance": "vitest run tests/acceptance/",
    "test:e2e": "vitest run tests/end-to-end/",
    "test:non-functional": "vitest run tests/non-functional/",
    "test:adversarial": "vitest run tests/adversarial/",
    "test:exploratory": "vitest run tests/exploratory/",
    "test:watch": "vitest",
    "mcp": "node --import tsx/esm src/surfaces/mcp/mcp_tools_entry.ts",
    "mcp:dev": "node --import tsx/esm --watch src/surfaces/mcp/mcp_tools_entry.ts",
    "cmf": "tsx src/surfaces/cli/cli_main_entry.ts",
    "tui": "tsx src/surfaces/tui/tui_main_entry.ts",
    "or:run": "tsx scripts/openrouter_local_runner.ts once",
    "or:daemon": "tsx scripts/openrouter_local_runner.ts daemon"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260402.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "commander": "^14.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.81.0",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@react-router/dev": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "isbot": "^5",
    "picocolors": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postal-mime": "^2.7.4",
    "vite": "^8.0.10",
    "zod": "^3.23.8"
  },
  "author": "rakaarwaky <arwaky90@gmail.com>"
}